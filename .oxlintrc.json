{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "react",
    "react-perf",
    "jsx-a11y",
    "nextjs",
    "promise"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "settings": {
    "next": {
      "rootDir": "apps/web"
    },
    "react": {
      "version": "19.2.4"
    }
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/.turbo/**",
    "**/coverage/**",
    "**/build/**",
    "**/.agents/**",
    "**/.claude/**",
    "**/.pnpm-store/**",
    "**/*.d.ts",
    "**/*.d.ts.map",
    "**/*.js",
    "**/*.js.map",
    "apps/**/*.js",
    "packages/**/*.js"
  ],
  "rules": {
    "complexity": ["error", 12],
    "import/no-unassigned-import": "off",
    "import/no-cycle": "error",
    "max-depth": ["error", 3],
    "max-lines": [
      "error",
      {
        "max": 500,
        "skipBlankLines": true,
        "skipComments": true
      }
    ],
    "max-lines-per-function": [
      "error",
      {
        "IIFEs": true,
        "max": 100,
        "skipBlankLines": true,
        "skipComments": true
      }
    ],
    "max-nested-callbacks": ["error", 3],
    "max-params": ["error", 4],
    "max-statements": ["error", 40],
    "react/react-in-jsx-scope": "off",
    "react-perf/jsx-no-new-array-as-prop": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react-perf/jsx-no-jsx-as-prop": "off",
    "react-perf/jsx-no-new-object-as-prop": "off",
    "typescript/consistent-type-imports": "error",
    "typescript/no-explicit-any": "error",
    "unicorn/no-array-sort": "off",
    "unicorn/filename-case": [
      "error",
      {
        "cases": {
          "camelCase": true,
          "kebabCase": true,
          "pascalCase": true
        },
        "ignore": [
          "^\\+[a-z0-9]+(?:-[a-z0-9]+)*\\.[cm]?[jt]sx?$",
          "^\\(.*\\)\\.[cm]?[jt]sx?$",
          "^.*\\.d\\.[cm]?ts$",
          "^_layout\\.[cm]?[jt]sx?$",
          "^\\[.*\\]\\.[cm]?[jt]sx?$",
          "^[a-z]+\\.config\\.[cm]?[jt]s$",
          "^next-env\\.d\\.ts$"
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/app/page.tsx",
        "**/app/dashboard/page.tsx",
        "**/app/dashboard/**/page.tsx",
        "**/components/fec/dashboard-sidebar.tsx",
        "**/components/fec/fec-dropzone.tsx",
        "**/lib/fec/analytics.ts",
        "**/lib/fec/demo.ts",
        "**/lib/fec/parser.ts",
        "**/lib/fec/store.tsx",
        "**/src/components/chart.tsx",
        "**/src/components/sidebar.tsx"
      ],
      "rules": {
        "complexity": ["error", 30],
        "max-lines": [
          "error",
          {
            "max": 700,
            "skipBlankLines": true,
            "skipComments": true
          }
        ],
        "max-lines-per-function": [
          "error",
          {
            "IIFEs": true,
            "max": 350,
            "skipBlankLines": true,
            "skipComments": true
          }
        ],
        "max-params": ["error", 5],
        "max-statements": ["error", 75]
      }
    },
    {
      "files": ["**/*.spec.*", "**/*.test.*"],
      "rules": {
        "max-lines-per-function": [
          "error",
          {
            "IIFEs": true,
            "max": 120,
            "skipBlankLines": true,
            "skipComments": true
          }
        ],
        "max-statements": ["error", 60]
      }
    }
  ]
}
